{
  "expo": {
    "name": "PowerPilot",
    "slug": "powerpilot",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#0a0e1a"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "PowerPilot needs your location to show nearest electricity board offices.",
        "NSLocationAlwaysUsageDescription": "PowerPilot needs your location to show nearest service centres."
      },
      "config": {
        "googleMapsApiKey": "AIzaSyCL-PHtH29PgOHcIZRcepUjr911fhotT0E"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0a0e1a"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCL-PHtH29PgOHcIZRcepUjr911fhotT0E"
        }
      },
      "package": "com.arshchakrabortysorganization.powerpilot"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-web-browser",
      "expo-location",
      "expo-sharing"
    ],
    "extra": {
      "eas": {
        "projectId": "65e8506a-3d2f-49f3-96cb-ea82615b28e0"
      }
    },
    "owner": "arshchakrabortys-organization"
  }
}
